<!doctype html>
<html lang="en" dir="ltr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blogs · Sayanta</title>
  <meta name="description" content="Blogs" />
  <!-- External CSS -->
  <link rel="preconnect" href="https://rsms.me/" />
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  <!-- Base Style -->
  <link rel="stylesheet" href="/css/base/preflight.css" />
  <link rel="stylesheet" href="/css/base/theme.css" />
  <link rel="stylesheet" href="/css/base/default.css" />
  <link rel="stylesheet" href="/css/base/font.css" />
  <!-- Layout -->
  <link rel="stylesheet" href="/css/layout/layout.css" />
  <!-- Components -->
  <link rel="stylesheet" href="/css/components/button.css" />
  <link rel="stylesheet" href="/css/components/card.css" />
  <!-- JS -->
  <script src="/js/navbar.js" defer></script>
  <script src="/js/script.js" defer></script>
</head>

<body>
  <header class="page-header">
    <h1>Blogs</h1>
    <p class="lead">Thoughts, tutorials, and insights on programming.</p>
  </header>

  <main class="container-md">
    <div class="cards">
      {% for post in collections.post | reverse %}
      <article class="card">
        <header class="card-header">
          <h3 class="card-title">{{ post.data.title }}</h3>
          <p class="card-subtitle">{{ post.data.date | readableDate }}</p>
        </header>
        <div class="card-body">
          <p class="card-text">{{ post.data.description }}</p>
        </div>
        <footer class="card-footer">
          <a href="{{ post.url }}" class="btn btn-outline">Read more</a>
        </footer>
      </article>
      {% endfor %}
    </div>
  </main>

  <hr />

  <footer class="site-footer container">
    <p>&copy; 2026 · Design &amp; Developed by Sayanta Chaudhary</p>
  </footer>
</body>

</html>
