<!doctype html>
<html lang="en" dir="ltr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }} </title>
  <meta name="description" content="{{ description }}" />
  <!-- Social Meta -->
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://sayanta.is-a-fullstack.dev/blog/{{ page.fileSlug }}/" />
  <meta property="og:image" content="https://sayanta.is-a-fullstack.dev{{ image }}" />
  <!-- Base Style -->
  <link rel="stylesheet" href="/css/base/preflight.css" />
  <link rel="stylesheet" href="/css/base/font.css" />
  <link rel="stylesheet" href="/css/base/theme.css" />
  <link rel="stylesheet" href="/css/base/global.css" />
  <!-- Layout -->
  <link rel="stylesheet" href="/css/layout/layout.css" />
  <!-- Components -->
  <link rel="stylesheet" href="/css/components/button.css" />
  <!-- Page Specific -->
  <link rel="stylesheet" href="/css/pages/post.css" />
  <!-- JS -->
  <script src="/js/dark-mode.js"></script>
  <script src="/js/navbar.js" defer></script>
  <script src="/js/script.js" defer></script>
  <script src="/js/likes.js"></script>
  <!-- Highlight.js -->
  <link rel="stylesheet" class="hljs-theme"
    href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/atom-one-light.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
</head>

<body>
  <main class="container-md">
    <article class="post">
      <header class="post-header">
        <button class="btn btn-ghost btb" onclick="navigation.back()">
          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256">
            <path
              d="M232,144a64.07,64.07,0,0,1-64,64H80a8,8,0,0,1,0-16h88a48,48,0,0,0,0-96H51.31l34.35,34.34a8,8,0,0,1-11.32,11.32l-48-48a8,8,0,0,1,0-11.32l48-48A8,8,0,0,1,85.66,45.66L51.31,80H168A64.07,64.07,0,0,1,232,144Z">
            </path>
          </svg>
          Back to Blog
        </button>
        <h1>{{ title }}</h1>
        <div class="post-meta">
          <time datetime="{{ date }}">{{ date | readableDate }}</time>
        </div>
      </header>
      {{ content | safe }}
      <footer class="post-footer">
        <button title="like" class="btn btn-primary like-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256">
            <path d="M80,104V208H32a8,8,0,0,1-8-8V112a8,8,0,0,1,8-8Z" opacity="0.2"></path>
            <path
              d="M234,80.12A24,24,0,0,0,216,72H160V56a40,40,0,0,0-40-40,8,8,0,0,0-7.16,4.42L75.06,96H32a16,16,0,0,0-16,16v88a16,16,0,0,0,16,16H204a24,24,0,0,0,23.82-21l12-96A24,24,0,0,0,234,80.12ZM32,112H72v88H32ZM223.94,97l-12,96a8,8,0,0,1-7.94,7H88V105.89l36.71-73.43A24,24,0,0,1,144,56V80a8,8,0,0,0,8,8h64a8,8,0,0,1,7.94,9Z">
            </path>
          </svg>
          <span class="like-count">0</span>
        </button>
      </footer>
    </article>

    <hr />
  </main>

  <script>
    hljs.highlightAll();

    const pid = "{{ page.fileSlug }}";
    getLikes(pid).then((count) => {
      document.querySelector(".like-count").textContent = count;
    });
    document.querySelector(".like-btn").addEventListener("click", async () => {
      await addLike(pid);
      const count = await getLikes(pid);
      document.querySelector(".like-count").textContent = count;
    });
  </script>
</body>

</html>
